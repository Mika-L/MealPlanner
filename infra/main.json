{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.45.15.27210",
      "templateHash": "2759392059537409703"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "allowedValues": [
        "dev",
        "prod"
      ],
      "metadata": {
        "description": "Nom court de l'environnement (dev, prod)."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "francecentral",
      "metadata": {
        "description": "Région Azure."
      }
    },
    "containerImage": {
      "type": "string",
      "metadata": {
        "description": "Image conteneur complète à déployer (ex. ghcr.io/mika-l/mealplanner:<sha>)."
      }
    },
    "jwtSigningKey": {
      "type": "securestring",
      "metadata": {
        "description": "Clé de signature JWT (>= 32 octets). Injectée comme secret du Container App."
      }
    },
    "sqlAdminLogin": {
      "type": "string",
      "metadata": {
        "description": "Login de l'administrateur Entra du serveur SQL (nom d'affichage du principal déployeur)."
      }
    },
    "sqlAdminObjectId": {
      "type": "string",
      "metadata": {
        "description": "Object ID (SID) du principal Entra administrateur du serveur SQL."
      }
    },
    "sqlAdminPrincipalType": {
      "type": "string",
      "defaultValue": "Application",
      "allowedValues": [
        "User",
        "Group",
        "Application"
      ],
      "metadata": {
        "description": "Type de principal administrateur Entra."
      }
    }
  },
  "variables": {
    "namePrefix": "[format('mealplanner-{0}', parameters('environmentName'))]",
    "databaseName": "mealplanner",
    "uniqueSuffix": "[uniqueString(resourceGroup().id)]",
    "sqlServerName": "[format('sql-{0}-{1}', variables('namePrefix'), variables('uniqueSuffix'))]"
  },
  "resources": [
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('id-{0}', variables('namePrefix'))]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[format('log-{0}', variables('namePrefix'))]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[format('cae-{0}', variables('namePrefix'))]",
      "location": "[parameters('location')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', format('log-{0}', variables('namePrefix'))), '2023-09-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', format('log-{0}', variables('namePrefix'))), '2023-09-01').primarySharedKey]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', format('log-{0}', variables('namePrefix')))]"
      ]
    },
    {
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2023-08-01-preview",
      "name": "[variables('sqlServerName')]",
      "location": "[parameters('location')]",
      "properties": {
        "minimalTlsVersion": "1.2",
        "publicNetworkAccess": "Enabled",
        "administrators": {
          "administratorType": "ActiveDirectory",
          "principalType": "[parameters('sqlAdminPrincipalType')]",
          "login": "[parameters('sqlAdminLogin')]",
          "sid": "[parameters('sqlAdminObjectId')]",
          "tenantId": "[subscription().tenantId]",
          "azureADOnlyAuthentication": true
        }
      }
    },
    {
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', variables('sqlServerName'), 'AllowAllWindowsAzureIps')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ]
    },
    {
      "type": "Microsoft.Sql/servers/databases",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', variables('sqlServerName'), variables('databaseName'))]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "GP_S_Gen5",
        "tier": "GeneralPurpose",
        "family": "Gen5",
        "capacity": 2
      },
      "properties": {
        "autoPauseDelay": 60,
        "minCapacity": "[json('0.5')]",
        "maxSizeBytes": 34359738368,
        "useFreeLimit": true,
        "freeLimitExhaustionBehavior": "AutoPause",
        "zoneRedundant": false,
        "collation": "SQL_Latin1_General_CP1_CI_AS"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[format('ca-{0}', variables('namePrefix'))]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-{0}', variables('namePrefix'))))]": {}
        }
      },
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', format('cae-{0}', variables('namePrefix')))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 8080,
            "transport": "auto"
          },
          "secrets": [
            {
              "name": "jwt-signing-key",
              "value": "[parameters('jwtSigningKey')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "api",
              "image": "[parameters('containerImage')]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              },
              "env": [
                {
                  "name": "ASPNETCORE_ENVIRONMENT",
                  "value": "Production"
                },
                {
                  "name": "ASPNETCORE_HTTP_PORTS",
                  "value": "8080"
                },
                {
                  "name": "ConnectionStrings__MealsDb",
                  "value": "[format('Server=tcp:{0},1433;Initial Catalog={1};Authentication=Active Directory Managed Identity;User Id={2};Encrypt=True;', reference(resourceId('Microsoft.Sql/servers', variables('sqlServerName')), '2023-08-01-preview').fullyQualifiedDomainName, variables('databaseName'), reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-{0}', variables('namePrefix'))), '2023-01-31').clientId)]"
                },
                {
                  "name": "ConnectionStrings__IdentityDb",
                  "value": "[format('Server=tcp:{0},1433;Initial Catalog={1};Authentication=Active Directory Managed Identity;User Id={2};Encrypt=True;', reference(resourceId('Microsoft.Sql/servers', variables('sqlServerName')), '2023-08-01-preview').fullyQualifiedDomainName, variables('databaseName'), reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-{0}', variables('namePrefix'))), '2023-01-31').clientId)]"
                },
                {
                  "name": "Jwt__SigningKey",
                  "secretRef": "jwt-signing-key"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 0,
            "maxReplicas": 1
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', format('cae-{0}', variables('namePrefix')))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-{0}', variables('namePrefix')))]",
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ]
    }
  ],
  "outputs": {
    "containerAppFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', format('ca-{0}', variables('namePrefix'))), '2024-03-01').configuration.ingress.fqdn]"
    },
    "sqlServerFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Sql/servers', variables('sqlServerName')), '2023-08-01-preview').fullyQualifiedDomainName]"
    },
    "sqlDatabaseName": {
      "type": "string",
      "value": "[variables('databaseName')]"
    },
    "managedIdentityName": {
      "type": "string",
      "value": "[format('id-{0}', variables('namePrefix'))]"
    },
    "managedIdentityClientId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-{0}', variables('namePrefix'))), '2023-01-31').clientId]"
    }
  }
}