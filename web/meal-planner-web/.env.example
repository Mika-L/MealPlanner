# ID client OAuth Google (public) — requis pour activer « Continuer avec Google ».
# Doit correspondre à Authentication:Google:ClientId côté API (audience des id_token).
# Console : https://console.cloud.google.com/apis/credentials → identifiant OAuth « Web ».
# Origines JavaScript autorisées : http://localhost:5173 (dev) + l'URL de prod.
# Sans cette variable, le bouton Google reste inactif ; l'auth email/mot de passe fonctionne.
VITE_GOOGLE_CLIENT_ID=
